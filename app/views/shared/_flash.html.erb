<% if type == "notice" %>
  <div class="bg-green-900/50 border border-green-700 text-green-200 px-4 py-3 rounded-xl relative mb-4 animate-fade-in" role="alert">
    <span class="block sm:inline"><%= message %></span>
  </div>
<% elsif type == "alert" %>
  <div class="bg-red-900/50 border border-red-700 text-red-200 px-4 py-3 rounded-xl relative mb-4 animate-fade-in" 
       role="alert"
       data-controller="flash"
       data-action="animationend->flash#remove">
    <span class="block sm:inline"><%= message %></span>
  </div>
<% end %> 