<div class="max-w-4xl mx-auto">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-white">Whispr</h1>
    <div class="flex space-x-3">
      <%= link_to "Recent", root_path, 
          class: "px-4 py-2 rounded-full text-sm font-medium transition-colors duration-200 #{params[:tab].nil? ? 'bg-indigo-500 text-white hover:bg-indigo-400' : 'bg-gray-800 text-gray-300 hover:bg-gray-700'}" %>
      <%= link_to "Trending", root_path(tab: 'trending'), 
          class: "px-4 py-2 rounded-full text-sm font-medium transition-colors duration-200 #{params[:tab] == 'trending' ? 'bg-indigo-500 text-white hover:bg-indigo-400' : 'bg-gray-800 text-gray-300 hover:bg-gray-700'}" %>
    </div>
  </div>

  <div class="bg-gray-800 rounded-xl shadow-sm p-6 mb-8 border border-gray-700">
    <h2 class="text-xl font-semibold mb-4 text-white">Share Your Confession</h2>
    <%= form_with(model: @confession, class: "space-y-4") do |f| %>
      <div>
        <%= f.text_area :body, 
            class: "w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent text-gray-100 placeholder-gray-500", 
            rows: 4, 
            placeholder: "What's on your mind? (max 500 characters)", 
            maxlength: 500 %>
      </div>
      <div class="flex justify-end">
        <%= f.submit "Share Anonymously", 
            class: "px-5 py-2.5 bg-indigo-500 text-white text-sm font-medium rounded-full hover:bg-indigo-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-gray-800 transition-colors duration-200" %>
      </div>
    <% end %>
  </div>

  <div class="columns-1 sm:columns-2 md:columns-3 gap-6 space-y-6 [&>*]:break-inside-avoid-column">
    <%= render partial: "confession", collection: @confessions %>
  </div>
</div>
