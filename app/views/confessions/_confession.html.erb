<div id="<%= dom_id(confession) %>" class="bg-gray-800 rounded-xl shadow-sm p-6 mb-6 relative group hover:shadow-md transition-all duration-200 border border-gray-700">
  <% if confession.reactions_count >= 30 %>
    <div class="absolute -top-2 -right-2 bg-gradient-to-r from-indigo-500 to-purple-500 text-white text-xs font-medium px-2.5 py-1 rounded-full shadow-sm">
      🔥 Trending
    </div>
  <% end %>

  <div class="flex justify-between items-start mb-4">
    <p class="text-gray-100 text-base leading-relaxed"><%= confession.body %></p>
    <span class="text-xs text-gray-400 font-medium whitespace-nowrap ml-4">
      <%= time_ago_in_words(confession.created_at) %> ago
    </span>
  </div>
  
  <div class="flex items-center space-x-2">
    <%= button_to confession_reactions_path(confession), 
        params: { reaction: { reaction_type: 'like' } },
        class: "group flex items-center space-x-1.5 px-3 py-1.5 rounded-full bg-gray-900/50 hover:bg-rose-900/50 transition-colors duration-200",
        data: { controller: "reaction", action: "click->reaction#animate" },
        form: { data: { turbo: true } } do %>
      <span data-reaction-target="emoji" class="transform group-hover:scale-125 transition-transform duration-200">❤️</span>
      <span data-reaction-target="count" class="text-sm font-medium text-gray-400 group-hover:text-rose-300 transition-colors duration-200"><%= confession.reactions.where(reaction_type: 'like').count %></span>
    <% end %>

    <%= button_to confession_reactions_path(confession), 
        params: { reaction: { reaction_type: 'hug' } },
        class: "group flex items-center space-x-1.5 px-3 py-1.5 rounded-full bg-gray-900/50 hover:bg-indigo-900/50 transition-colors duration-200",
        data: { controller: "reaction", action: "click->reaction#animate" },
        form: { data: { turbo: true } } do %>
      <span data-reaction-target="emoji" class="transform group-hover:scale-125 transition-transform duration-200">🤗</span>
      <span data-reaction-target="count" class="text-sm font-medium text-gray-400 group-hover:text-indigo-300 transition-colors duration-200"><%= confession.reactions.where(reaction_type: 'hug').count %></span>
    <% end %>

    <%= button_to confession_reactions_path(confession), 
        params: { reaction: { reaction_type: 'laugh' } },
        class: "group flex items-center space-x-1.5 px-3 py-1.5 rounded-full bg-gray-900/50 hover:bg-amber-900/50 transition-colors duration-200",
        data: { controller: "reaction", action: "click->reaction#animate" },
        form: { data: { turbo: true } } do %>
      <span data-reaction-target="emoji" class="transform group-hover:scale-125 transition-transform duration-200">😂</span>
      <span data-reaction-target="count" class="text-sm font-medium text-gray-400 group-hover:text-amber-300 transition-colors duration-200"><%= confession.reactions.where(reaction_type: 'laugh').count %></span>
    <% end %>
  </div>
</div> 