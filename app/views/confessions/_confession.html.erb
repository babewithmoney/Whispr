<div id="<%= dom_id(confession) %>" class="bg-white rounded-lg shadow-md p-6">
  <p class="text-gray-800 mb-4"><%= confession.body %></p>
  
  <div class="flex items-center justify-between">
    <div class="flex space-x-2">
      <%= button_to confession_reactions_path(confession), 
          params: { reaction: { reaction_type: 'like' } },
          class: "flex items-center space-x-1 px-3 py-1 rounded-lg bg-gray-100 hover:bg-gray-200",
          form: { data: { turbo: true } } do %>
        <span>❤️</span>
        <span class="text-sm"><%= confession.reactions.where(reaction_type: 'like').count %></span>
      <% end %>

      <%= button_to confession_reactions_path(confession), 
          params: { reaction: { reaction_type: 'hug' } },
          class: "flex items-center space-x-1 px-3 py-1 rounded-lg bg-gray-100 hover:bg-gray-200",
          form: { data: { turbo: true } } do %>
        <span>🤗</span>
        <span class="text-sm"><%= confession.reactions.where(reaction_type: 'hug').count %></span>
      <% end %>

      <%= button_to confession_reactions_path(confession), 
          params: { reaction: { reaction_type: 'laugh' } },
          class: "flex items-center space-x-1 px-3 py-1 rounded-lg bg-gray-100 hover:bg-gray-200",
          form: { data: { turbo: true } } do %>
        <span>😂</span>
        <span class="text-sm"><%= confession.reactions.where(reaction_type: 'laugh').count %></span>
      <% end %>
    </div>

    <span class="text-sm text-gray-500">
      <%= time_ago_in_words(confession.created_at) %> ago
    </span>
  </div>
</div> 